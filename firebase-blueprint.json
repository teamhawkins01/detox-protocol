{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Detox.Recipes platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID from Firebase Auth." },
        "username": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "avatar": { "type": "string", "description": "URL to the user's avatar image." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role." },
        "status": { "type": "string", "enum": ["active", "suspended", "banned"], "description": "The user's current status." },
        "suspensionUntil": { "type": "string", "format": "date-time", "description": "If suspended, until when." },
        "savedProtocols": { "type": "array", "items": { "type": "string" }, "description": "List of protocol IDs in the digital archive." },
        "stats": {
          "type": "object",
          "properties": {
            "protocolsGenerated": { "type": "integer", "default": 0 },
            "reviewsLeft": { "type": "integer", "default": 0 },
            "tweaksSuggested": { "type": "integer", "default": 0 },
            "photosUploaded": { "type": "integer", "default": 0 },
            "smoothiesGenerated": { "type": "integer", "default": 0 }
          }
        }
      },
      "required": ["uid", "username", "email", "role", "avatar"]
    },
    "Protocol": {
      "title": "Protocol",
      "description": "A detox protocol.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the protocol." },
        "ingredients": { "type": "array", "items": { "type": "string" }, "description": "List of ingredients." },
        "instructions": { "type": "string", "description": "Step-by-step instructions." },
        "category": { 
          "type": "string", 
          "enum": [
            "Juices & Smoothies", 
            "Waters & Drinks", 
            "Weight Loss & Cleanses", 
            "Targeted Detox", 
            "Detox Baths", 
            "Soups & Meals"
          ],
          "description": "The category of the protocol."
        },
        "authorId": { "type": "string", "description": "The UID of the user who created the protocol." },
        "authorType": { "type": "string", "enum": ["Admin", "User"], "description": "Whether the author is an admin or a user." },
        "authorName": { "type": "string", "description": "The display name of the author." },
        "authorLevel": { "type": "integer", "description": "The level of the author at the time of creation." },
        "isAiGenerated": { "type": "boolean", "description": "Whether the protocol was generated by AI." },
        "photoUrl": { "type": "string", "description": "URL to the protocol photo." },
        "pioneerUserId": { "type": "string", "description": "The UID of the first user to upload a photo." },
        "pioneerUserName": { "type": "string", "description": "The display name of the first user to upload a photo." },
        "pioneerUserAvatar": { "type": "string", "description": "The avatar of the first user to upload a photo." },
        "ingredientBenefits": { "type": "array", "items": { "type": "string" }, "description": "Benefits of each ingredient." },
        "rationale": { "type": "string", "description": "Why the AI put these ingredients together." },
        "outcome": { "type": "string", "description": "Why it is good for the user." },
        "starRating": { "type": "number", "description": "The average star rating of the protocol." },
        "moderationStatus": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "The moderation status of user-submitted protocols." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "prepTime": { "type": "string", "description": "Preparation time in ISO 8601 duration format." },
        "cookTime": { "type": "string", "description": "Cooking time in ISO 8601 duration format." },
        "totalTime": { "type": "string", "description": "Total time in ISO 8601 duration format." },
        "protocolYield": { "type": "string", "description": "The quantity produced by the protocol." },
        "isMasterCrafted": { "type": "boolean", "default": false, "description": "Whether the protocol was crafted by a Level 10 Alchemist." },
        "targetHealthGoal": { "type": "string", "description": "The specific health goal targeted by the protocol (Master Tier feature)." },
        "suitableForDiet": { "type": "array", "items": { "type": "string" }, "description": "Diets the protocol is suitable for." },
        "keywords": { "type": "array", "items": { "type": "string" }, "description": "SEO keywords." },
        "nutrition": {
          "type": "object",
          "properties": {
            "calories": { "type": "string" },
            "fatContent": { "type": "string" },
            "proteinContent": { "type": "string" },
            "carbohydrateContent": { "type": "string" },
            "fiberContent": { "type": "string" }
          }
        }
      },
      "required": ["title", "ingredients", "instructions", "category", "authorId", "authorType", "isAiGenerated", "createdAt"]
    },
    "SystemLog": {
      "title": "SystemLog",
      "description": "A log entry for system activity.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["login", "login_attempt", "auth_error", "admin_action", "user_action", "page_view"], "description": "The type of log entry." },
        "userId": { "type": "string", "description": "The UID of the user involved." },
        "email": { "type": "string", "description": "The email of the user involved." },
        "details": { "type": "string", "description": "Detailed description of the event." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the event occurred." },
        "userAgent": { "type": "string", "description": "The user's browser agent." }
      },
      "required": ["type", "timestamp", "details"]
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Page view analytics.",
      "type": "object",
      "properties": {
        "page": { "type": "string", "description": "The page path visited." },
        "userId": { "type": "string", "description": "The UID of the user (if logged in)." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the page was visited." },
        "userAgent": { "type": "string", "description": "The user's browser agent." }
      },
      "required": ["page", "timestamp"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a protocol.",
      "type": "object",
      "properties": {
        "protocolId": { "type": "string", "description": "The ID of the protocol being reviewed." },
        "userId": { "type": "string", "description": "The UID of the user who wrote the review." },
        "username": { "type": "string", "description": "The username of the reviewer." },
        "avatar": { "type": "string", "description": "The avatar of the reviewer." },
        "userLevel": { "type": "integer", "description": "The level of the user at the time of review." },
        "userBadges": { "type": "array", "items": { "type": "string" }, "description": "The badges of the user at the time of review." },
        "rating": { "type": "integer", "minimum": 1, "maximum": 5, "description": "Star rating from 1 to 5." },
        "suggestion": { "type": "string", "description": "The 'Try adding this...' suggestion." },
        "photoUrl": { "type": "string", "description": "URL to a photo of the creation." },
        "moderationStatus": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "The moderation status of the review." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Review timestamp." }
      },
      "required": ["protocolId", "userId", "username", "rating", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A user like for a protocol.",
      "type": "object",
      "properties": {
        "protocolId": { "type": "string", "description": "The ID of the protocol." },
        "userId": { "type": "string", "description": "The UID of the user who liked the protocol." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Like timestamp." }
      },
      "required": ["protocolId", "userId", "createdAt"]
    },
    "Author": {
      "title": "Author",
      "description": "An official author for Detox.Recipes.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the author." },
        "name": { "type": "string", "description": "Display name of the author." },
        "bio": { "type": "string", "description": "Short biography." },
        "avatar": { "type": "string", "description": "URL to the author's photo." },
        "specialty": { "type": "string", "description": "The author's area of expertise (e.g., 'Juice Cleanses')." },
        "badges": { "type": "array", "items": { "type": "string" }, "description": "List of badge IDs (e.g., 'verified_author')." },
        "website": { "type": "string", "format": "uri", "description": "The author's official website." },
        "socialLinks": {
          "type": "object",
          "properties": {
            "twitter": { "type": "string" },
            "instagram": { "type": "string" },
            "facebook": { "type": "string" }
          }
        },
        "credentials": { "type": "array", "items": { "type": "string" }, "description": "Professional credentials (e.g., MD, PhD)." }
      },
      "required": ["id", "name", "bio", "avatar"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/authors/{authorId}": {
      "schema": "Author",
      "description": "Official author profiles."
    },
    "/protocols/{protocolId}": {
      "schema": "Protocol",
      "description": "Detox protocols."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Protocol reviews."
    },
    "/likes/{likeId}": {
      "schema": "Like",
      "description": "Protocol likes."
    },
    "/system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "System activity logs."
    },
    "/analytics/{viewId}": {
      "schema": "Analytics",
      "description": "Page view analytics."
    }
  }
}
